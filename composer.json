{
    "name": "gt264/crud-fiesta",
    "description": "A Laravel package for rapid CRUD operations with Inertia.js and Spatie Permissions support",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Michele Ferretti",
            "email": "ferretti.m91@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "laravel/framework": "^12.0",
        "inertiajs/inertia-laravel": "^2.0",
        "spatie/laravel-permission": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "GT264\\CrudFiesta\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GT264\\CrudFiesta\\CrudFiestaServiceProvider"
            ]
        }
    }
}